<view class="container">
  <view class="card header">
    <view class="title">代理点库存</view>
    <view class="muted">低库存商品会优先提示补货</view>
  </view>

  <view class="card stock-card" wx:for="{{stocks}}" wx:key="id">
    <view class="stock-top">
      <view>
        <view class="name">{{item.name}}</view>
        <view class="muted">分类：{{item.categoryName}}</view>
      </view>
      <view class="stock-count {{item.stock <= item.warningStock ? 'warning' : ''}}">{{item.stock}}</view>
    </view>
    <view class="stock-bottom">
      <text>预警库存：{{item.warningStock}}</text>
      <text>{{item.statusText}}</text>
    </view>
  </view>
</view>
