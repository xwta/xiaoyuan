<view class="container">
  <view class="card status-card">
    <view class="status-title">{{order.statusText}}</view>
    <view class="muted">{{order.deliveryText}}</view>
  </view>

  <view class="card">
    <view class="section-title">收货/自提信息</view>
    <view>{{order.contactName}} {{order.phone}}</view>
    <view class="muted">{{order.addressText}}</view>
  </view>

  <view class="card" wx:if="{{order.verifyCode || order.pickupCode}}">
    <view class="section-title">自提取货码</view>
    <view class="verify-code">{{order.verifyCode || order.pickupCode}}</view>
  </view>

  <view class="card">
    <view class="section-title">商品明细</view>
    <view class="item-row" wx:for="{{order.items}}" wx:key="id">
      <text>{{item.name}} x{{item.quantity}}</text>
      <text>¥{{item.totalAmount}}</text>
    </view>
  </view>

  <view class="card">
    <view class="item-row"><text>商品金额</text><text>¥{{order.productAmount}}</text></view>
    <view class="item-row"><text>配送费</text><text>¥{{order.deliveryFee}}</text></view>
    <view class="item-row total"><text>实付金额</text><text class="price">¥{{order.payAmount}}</text></view>
  </view>

  <view class="footer card">
    <button class="primary-btn" loading="{{operating}}" bindtap="checkoutOrder">确认交易</button>
    <button loading="{{operating}}" bindtap="completeOrder">完成订单</button>
  </view>
</view>
