<view class="container">
  <view class="card address-card" wx:for="{{addresses}}" wx:key="id">
    <view class="address-main">{{item.campusName}} {{item.buildingName}} {{item.roomNo}}</view>
    <view class="muted">{{item.contactName}} {{item.phone}}</view>
    <view class="tag" wx:if="{{item.isDefault}}">默认地址</view>
  </view>

  <button class="primary-btn add-btn" bindtap="goEdit">新增寝室地址</button>
</view>
