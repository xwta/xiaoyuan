.banner {
  background: linear-gradient(135deg, #fff4e6, #ffffff);
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.subtitle {
  color: #666;
  font-size: 26rpx;
}

.quick-entry {
  display: flex;
  justify-content: space-between;
}

.entry {
  width: 30%;
  text-align: center;
  padding: 20rpx 0;
  background: #fff7ed;
  border-radius: 16rpx;
  color: #ff7a00;
  font-weight: 600;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  margin: 24rpx 0;
}

.product-card {
  display: flex;
}

.product-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  background: #eee;
  margin-right: 20rpx;
}

.product-info {
  flex: 1;
}

.product-name {
  font-weight: 700;
  margin-bottom: 8rpx;
}

.product-desc {
  color: #888;
  font-size: 24rpx;
  margin-bottom: 24rpx;
}

.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
